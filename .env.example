# =============================================================================
# Manage Studio — environment map (NO real secrets in git)
# =============================================================================
# Copy to repo-root `.env` (gitignored). Shell env wins over this file.
#
# | Layer              | Where values live                         | Sync command              |
# |--------------------|-------------------------------------------|---------------------------|
# | Local scripts/CLI  | Repo-root `.env`                          | (load-env.mjs)            |
# | Vite SPA (browser) | `apps/web/.env.local` + Workers build vars | rebuild (not redeploy)  |
# | Edge Functions     | Supabase Project → Edge secrets           | `pnpm secrets:edge` etc.  |
# | DB GUCs / cron     | SQL `private.platform_config` (+ encryption GUC) | smoke:cron / runbook |
# | Per-tenant Grow    | Admin UI → bundled payments (DB encrypted)| NOT in .env               |
#
# Production: use a SEPARATE Supabase project + Cloudflare Workers production vars.
# SPA host is Cloudflare Workers static assets (NOT Pages — no wildcard custom domains).
# Never commit `.env`, `.env.*.local`, or supabase/.temp/*-secrets.env
#
# PROD HYGIENE (must NOT be true/set on production Edge secrets):
#   GROW_MOCK, ICOUNT_MOCK, INVOICE4U_MOCK, GOOGLE_CALENDAR_MOCK, TRANZILA_MOCK,
#   SYNC_ISSUE_DOCUMENT_IN_DEV
# PROD MUST SET: APP_URL=https://<your-app-origin>  (not localhost)
# =============================================================================

# --- Supabase (CLI / scripts) ------------------------------------------------
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Public app URL (Edge: dunning links, GCal OAuth redirect_uri) -----------
# Local: http://localhost:5173
# Prod:  https://app.yourdomain.com
APP_URL=http://localhost:5173

# --- Cron (Edge secret + private.platform_config.cron_secret — same value) ---
CRON_SECRET=

# --- Email / auth hook (Edge — pnpm secrets:email / secrets:edge) ------------
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=
# Dashboard → Auth → Hooks → Send Email → Generate Secret
SEND_EMAIL_HOOK_SECRET=

# --- Google Calendar (Edge — pnpm secrets:google-calendar) --------------------
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_MOCK=true   # local stub only — unset on prod

# --- Grow platform (Edge — NOT tenant merchant keys) -------------------------
# GROW_API_BASE=https://sandbox.meshulam.co.il/api/light/server/1.0
# GROW_NOTIFY_URL=   # optional; derived from SUPABASE_URL when omitted
# GROW_MOCK=true         # local/mock only — unset on prod / live sandbox E2E
# INVOICE4U_MOCK=true    # Creative Ballet seed default; unset for live Invoice4U QA

# --- Document worker (Edge) --------------------------------------------------
# ISSUE_DOCUMENT_URL=
# SYNC_ISSUE_DOCUMENT_IN_DEV=true   # local only — unset on prod

# --- WhatsApp / Twilio (Edge — enable when shipping WA) ----------------------
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_VERIFY_SERVICE_SID=

# --- Other Edge optional -----------------------------------------------------
# WAIVER_LINK_SECRET=
# ANTHROPIC_API_KEY=
# DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# --- Vite SPA (also set in apps/web/.env.local and the Workers build) --------
# Prefer apps/web/.env.local for local Vite; Workers Builds vars for deploy.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_DEV_TENANT_SUBDOMAIN=creativeballet
# Legal footer links (optional until counsel pages exist)
# VITE_PRIVACY_POLICY_URL=https://yourdomain.com/privacy
# VITE_TERMS_URL=https://yourdomain.com/terms
# Sentry (optional — wire @sentry/react when ready)
# VITE_SENTRY_DSN=
# SENTRY_DSN=

# --- Playwright / e2e (optional) ---------------------------------------------
# PLAYWRIGHT_SEEDED_E2E=1
# PLAYWRIGHT_PARENT_E2E=1         # after pnpm seed:auth-parent + password login works
# PLAYWRIGHT_ADMIN_E2E=1          # after miriamrteller@gmail.com password login works
# PLAYWRIGHT_FINANCE_DEV=1
# E2E_PARENT_PASSWORD=devPassword123
# E2E_ADMIN_PASSWORD=devPassword123
