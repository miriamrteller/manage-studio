# Supabase (link CLI with `pnpm db:link` after setting project ref)
SUPABASE_PROJECT_REF=
# Database password from Dashboard → Project Settings → Database (required for `pnpm db:push` and `pnpm seed:dev`)
SUPABASE_DB_PASSWORD=
# Optional direct URL for psql (overrides ref + password): postgresql://postgres:...@db.<ref>.supabase.co:5432/postgres
# SUPABASE_DB_URL=

# Hosted auth/email diagnostics (scripts/check-auth-email-setup.mjs, scripts/seed-auth-parent.mjs)
# Get from Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: TEST_EMAIL=miriamrstern@gmail.com APP_CALLBACK_URL=http://localhost:5173/auth/callback
# Send Email Hook (send-auth-email): paste from Dashboard → Auth → Hooks → Generate Secret
# SEND_EMAIL_HOOK_SECRET=v1,whsec_...
# DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# Sentry (optional until P4 wired in main.tsx)
VITE_SENTRY_DSN=
SENTRY_DSN=

# Vite dev tenant
VITE_DEV_TENANT_SUBDOMAIN=
