# Supabase (link CLI with `pnpm db:link` after setting project ref)
SUPABASE_PROJECT_REF=
# Database password from Dashboard → Project Settings → Database (required for psql smokes/seeds)
# Must be the real password — not a placeholder. On Windows, scripts auto-use the linked
# session pooler when db.<ref>.supabase.co is IPv6-only (or set SUPABASE_DB_URL explicitly).
SUPABASE_DB_PASSWORD=
# Optional direct URL for psql (overrides ref + password).
# On Windows, prefer the full URI from Dashboard → Database → Connection string (Session mode);
# the built-in db.<ref>.supabase.co host is IPv6-only and often fails to resolve locally.
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Cron smoke + GUC setup (scripts/smoke-cron-dev.mjs — same value as Edge Functions secret)
# CRON_SECRET=

# Google Calendar (appointment scheduling — Edge Function OAuth)
# Push to hosted Supabase: pnpm secrets:google-calendar
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# OAuth redirect is derived from APP_URL: {APP_URL}/admin/setup/integrations/google/callback
# Register that URI in Google Cloud Console → OAuth client → Authorized redirect URIs
# Set GOOGLE_CALENDAR_MOCK=true locally only to stub Google (do not set on production)
# GOOGLE_CALENDAR_MOCK=

# Hosted auth/email diagnostics (scripts/check-auth-email-setup.mjs, scripts/seed-auth-parent.mjs)
# Get from Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: TEST_EMAIL=miriamrstern@gmail.com APP_CALLBACK_URL=http://localhost:5173/auth/callback
# Send Email Hook (send-auth-email): paste from Dashboard → Auth → Hooks → Generate Secret
# SEND_EMAIL_HOOK_SECRET=v1,whsec_...
# DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# Sentry (optional until P4 wired in main.tsx)
VITE_SENTRY_DSN=
SENTRY_DSN=

# Vite dev tenant
VITE_DEV_TENANT_SUBDOMAIN=
