# =============================================================================
# Vite SPA — local only (gitignored as .env.local)
# =============================================================================
# Browser-exposed vars must be VITE_*. Never put service_role or CRON here.
# Production: VITE_* vars are inlined at build time, so set them on the build that runs
# `vite build` (Workers Builds → Settings → Variables, or your CI). They are NOT runtime
# Worker vars — changing them requires a rebuild, not just a redeploy.
# Edge secrets live in Supabase (pnpm secrets:edge) — see repo-root .env.example.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Root domain tenant subdomains hang off. Prod: opalswift.com
# (so creativeballet.opalswift.com). Defaults to localhost:5173 when unset.
VITE_APP_ROOT_DOMAIN=localhost:5173

# Dev-only tenant fallback for plain http://localhost:5173 (no subdomain in the host).
# IGNORED in production builds by design — if it were honoured, every unmatched host
# would silently serve this tenant's data.
VITE_DEV_TENANT_SUBDOMAIN=creativeballet

# Self-serve signup wizard at /create-studio. Off by default: it provisions a tenant
# with no payment gate. provision_tenant is also granted to service_role only, so
# enabling this alone is not enough — the RPC grant would have to be widened too.
# VITE_ENABLE_SELF_SERVE_SIGNUP=false

# Optional legal footer (SPEC §7) — absolute HTTPS URLs
# VITE_PRIVACY_POLICY_URL=https://yourdomain.com/privacy
# VITE_TERMS_URL=https://yourdomain.com/terms

# Optional Sentry (install @sentry/react before enabling)
# VITE_SENTRY_DSN=

# Auth redirect URLs (Supabase Dashboard — not env vars):
#   http://localhost:5173/auth/callback
#   https://YOUR_PRODUCTION_DOMAIN/auth/callback
# See docs/deployment/AUTH_EMAIL_SETUP.md
