# ============================================================================
# Supabase Configuration
# ============================================================================
# Get these values from Supabase dashboard:
# 1. Go to Project Settings > API
# 2. Copy URL and Anon Key

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# Development Tenant
# ============================================================================
# Must match the subdomain created in supabase/seed.sql
# Default: ballet-school

VITE_DEV_TENANT_SUBDOMAIN=ballet-school

# CI accessibility tests use apps/web/.env.e2e (committed placeholders).
# Optionally set GitHub secrets VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY,
# VITE_DEV_TENANT_SUBDOMAIN to run E2E against a real dev Supabase project.

